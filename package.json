{
  "name": "mango-studio",
  "private": true,
  "version": "0.0.0",
  "description": "Mango Studio — AI-режиссёр коротких мультиков (production monorepo)",
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:watch": "turbo test:watch",
    "db:gen": "supabase gen types typescript --linked > packages/db/src/types.ts",
    "db:diff": "supabase db diff -f",
    "db:push": "supabase db push",
    "db:reset": "supabase db reset --linked",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "turbo": "^2.5.0",
    "typescript": "^5.6.3",
    "supabase": "^1.226.0"
  },
  "packageManager": "pnpm@10.32.1"
}
